# OpenAI-compatible API 配置
# 支持 OpenAI、Azure OpenAI、国内兼容网关（如 DeepSeek、通义等）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 可选：请求超时（毫秒）
LLM_TIMEOUT_MS=120000

# 可选：默认温度（0-2，越高越有创意）
LLM_TEMPERATURE=1.0

# 可选：数据根目录（默认 ./data）
# DATA_ROOT=./data

# 远端部署登录保护（单超管账号）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# Caddy 反向代理域名
# 设为你的公网域名（支持多个，逗号分隔，如 example.com,www.example.com）
# Caddy 会自动通过 Let's Encrypt 签发/续期 HTTPS 证书
# 公网需要放通 80 和 443 端口；留空则降级为 HTTP :80（此时 Secure cookie 会失效）
SITE_ADDRESS=

# ACME 通知邮箱（Let's Encrypt 证书到期/异常时通知用，可选但强烈建议设置）
ACME_EMAIL=
